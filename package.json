{
  "name": "chapterquest-platform",
  "version": "0.1.0",
  "private": true,
  "description": "LitCircle (ChapterQuest) — serverless reading platform monorepo",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "dev:frontend": "pnpm --filter @chapterquest/frontend dev",
    "dev:api": "pnpm --filter @chapterquest/functions dev",
    "build:functions": "pnpm --filter @chapterquest/functions build",
    "build:frontend": "pnpm --filter @chapterquest/frontend build"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
